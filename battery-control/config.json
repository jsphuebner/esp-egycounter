	"mqtt_math": {
		"aliases": [
			{
				"topic": "/meter/power",
				"alias": "meter"
			},
			{
				"topic": "/battery/power",
				"alias": "battery"
			}
		],
		"calculations": [
			{
				"expression": "meter + battery",
