{
	"broker": {
	    "address": "192.168.188.23",
	    "port": 1883,
	    "keepalive": 60
	},
	"meter": {
		"topic": "/ebz/readings",
		"rawtopic": "/ebz/raw"
	},
	"ccsctrl": {
	    "enablepin": "P9_30",
	    "ledpin": "P9_28",
	    "prechargepin": "P9_16",
	    "changeoverpin": "P9_14",
	    "pwmpin": "P9_42",
	    "pwmbase": "/sys/class/pwm/pwm-0:0/"
	},
	"tibber": {
		"broker": "a2zhmn2392zl2a.iot.eu-west-1.amazonaws.com",
		"uid": "209ad2f026855a9d895580f78d3519d6",
		"bridgeid": "1596765f34000",
		"eui": "ef8e95123eb82afe"
	},
	"inverter": {
		"tty485": "/dev/ttyUSB0",
		"ttyTTL": "/dev/ttyS0",
		"maxpower": 900
	},
	"charger": {
		"tty": "/dev/ttyUSB1",
		"can": "can0",
		"gpio": "P9_12",
		"_comment": "tty for Manson charger, CAN for Flatpack, GPIO for charger power relay"
	},
	"bms": {
	    "can": "can1",
	    "modulecount": 6
	},
	"logger": {
		"uri": "https://yourdomain.com/log/?key=<yourkey>&data="
	},
	"netzero": {
		"uvlothresh": 44,
		"uvlohyst": 45,
		"voltagekp": 500,
		"powerkp": 1,
		"powerki": 0.2,
		"chargevoltage": 52.6,
		"evpower": 5000
	},
	"deye_dummycloud": {
		"port": 10000,
		"bind_host": "0.0.0.0",
		"loglevel": "INFO"
	},
	"mqtt_math": {
		"aliases": [ {
				"topic": "deye-dummycloud/3851343667/grid/active_power_w",
				"alias": "P_deye"
			},{
				"topic": "sungrow/pv_power",
				"alias": "P_sungrow"
			},{
				"topic": "/ebz/readings",
				"alias": "meter_power",
				"key": "ptotal"
			},{
				"topic": "/ebz/readings",
				"alias": "meter_energy",
				"key": "etotal"
			}
		],
		"calculations": [{
				"expression": "meter_power",
				"result_topic": "/meter/power"
			},{
				"expression": "meter_energy",
				"result_topic": "/meter/energy"
			},{
				"expression": "P_sungrow + P_deye",
				"result_topic": "/math/powersum"
			}
		],
		"client_id": "mqtt_math"
	}
}
